{
  "manifest_version": 3,
  "name": "Asma Ul Husna Memorizer",
  "short_name": "Asma Husna",
  "version": "1.0.0",
  "description": "Learn and memorize the 99 Names of Allah with Bangla meanings, transliteration, audio, and saved local progress.",
  "icons": {
    "16": "assets/images/logo-16.png",
