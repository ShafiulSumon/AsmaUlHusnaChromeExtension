    "128": "assets/images/logo.png"
  },
  "action": {
    "default_title": "Asma Ul Husna Memorizer",
    "default_popup": "home.html",
    "default_icon": {
      "16": "assets/images/logo-16.png",
      "32": "assets/images/logo-32.png",
      "48": "assets/images/logo-48.png",
      "128": "assets/images/logo.png"
    }
  }
}
